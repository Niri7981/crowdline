generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "sqlite"
}

model EventPoolItem {
  id               String   @id @default(cuid())
  sourceKey        String
  externalEventId  String
  externalMarketId String?
  slug             String?
  title            String
  question         String
  category         String
  marketSymbol     String
  yesLabel         String
  noLabel          String
  startsAt         DateTime?
  endsAt           DateTime?
  durationSeconds  Int
  resolutionSource String
  sourceLabel      String
  externalUrl      String?
  currentPrice     Float?
  volumeUsd        Float?
  liquidityScore   Float?
  status           String
  playable         Boolean  @default(true)
  spectatorNote    String
  stageLabel       String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([sourceKey, externalEventId])
  @@index([status, playable])
  @@index([marketSymbol])
}

model MarketTick {
  id             String   @id @default(cuid())
  sourceKey      String
  marketId       String
  conditionId    String?
  tokenId        String
  side           String
  price          Float
  sourceLabel    String
  observedAt     DateTime
  rawPayloadHash String?
  createdAt      DateTime @default(now())

  @@unique([sourceKey, tokenId, observedAt])
  @@index([sourceKey, marketId, observedAt])
  @@index([tokenId, observedAt])
  @@index([conditionId])
}
