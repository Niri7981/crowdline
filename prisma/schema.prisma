generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "sqlite"
}

model Round {
  id               String       @id @default(cuid())
  status           String
  marketSymbol     String
  bankrollPerAgent Float
  durationSeconds  Int
  startsAt         DateTime?
  endsAt           DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  event            RoundEvent?
  agents           RoundAgent[]
  actions          Action[]
  actionTraceSteps ActionTraceStep[]
  priceSnapshots   RoundPriceSnapshot[]
  settlement       Settlement?
  battleProof      BattleProofRecord?
}

model EventPoolItem {
  id               String   @id @default(cuid())
  sourceKey        String
  externalEventId  String
  externalMarketId String?
  slug             String?
  title            String
  question         String
  category         String
  marketSymbol     String
  yesLabel         String
  noLabel          String
  startsAt         DateTime?
  endsAt           DateTime?
  durationSeconds  Int
  resolutionSource String
  sourceLabel      String
  externalUrl      String?
  currentPrice     Float?
  volumeUsd        Float?
  liquidityScore   Float?
  status           String
  playable         Boolean  @default(true)
  spectatorNote    String
  stageLabel       String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([sourceKey, externalEventId])
  @@index([status, playable])
  @@index([marketSymbol])
}

model AgentProfile {
  id             String    @id @default(cuid())
  identityKey    String    @unique
  runtimeKey     String
  name           String
  avatarSeed     String
  style          String
  riskProfile    String
  badge          String
  currentRank    Int
  previousRank   Int?
  totalWins      Int       @default(0)
  totalLosses    Int       @default(0)
  currentStreak  Int       @default(0)
  bestStreak     Int       @default(0)
  tagline        String
  isActive       Boolean   @default(true)
  brainProvider  String?
  brainModel     String?
  brainSwappedAt DateTime?
  externalEndpointUrl String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([isActive, currentRank])
  @@index([runtimeKey])
}

model RoundEvent {
  id               String   @id @default(cuid())
  roundId          String   @unique
  question         String
  resolutionSource String
  observationType  String?  @default("fact-price")
  sourceKey        String?
  externalMarketId String?
  slug             String?
  startPrice       Float
  endPrice         Float?
  outcome          String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  round            Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
}

model RoundAgent {
  id              String   @id @default(cuid())
  roundId         String
  agentKey        String
  name            String
  style           String
  riskProfile     String
  startingBalance Float
  finalBalance    Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  round           Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  actions         Action[]
  actionTraceSteps ActionTraceStep[]

  @@index([roundId])
  @@unique([roundId, agentKey])
}

model Action {
  id                String     @id @default(cuid())
  roundId           String
  roundAgentId      String
  snapshotId        String?
  side              String
  sizeUsd           Float
  reason            String
  runtimeKey        String?
  brainProvider     String?
  brainModel        String?
  executionProvider String?
  executionModel    String?
  executionStatus   String?
  createdAt         DateTime   @default(now())
  round             Round      @relation(fields: [roundId], references: [id], onDelete: Cascade)
  roundAgent        RoundAgent @relation(fields: [roundAgentId], references: [id], onDelete: Cascade)
  snapshot          RoundPriceSnapshot? @relation(fields: [snapshotId], references: [id], onDelete: SetNull)
  traceSteps        ActionTraceStep[]

  @@index([roundId])
  @@index([roundAgentId])
  @@index([roundId, snapshotId])
  @@index([runtimeKey])
  @@index([brainProvider, brainModel])
}

model ActionTraceStep {
  id           String     @id @default(cuid())
  actionId     String
  roundId      String
  roundAgentId String
  stepIndex    Int
  phase        String
  title        String
  detail       String
  createdAt    DateTime   @default(now())
  action       Action     @relation(fields: [actionId], references: [id], onDelete: Cascade)
  round        Round      @relation(fields: [roundId], references: [id], onDelete: Cascade)
  roundAgent   RoundAgent @relation(fields: [roundAgentId], references: [id], onDelete: Cascade)

  @@unique([actionId, stepIndex])
  @@index([roundId])
  @@index([roundAgentId])
  @@index([phase])
}

model Settlement {
  id               String   @id @default(cuid())
  roundId          String   @unique
  status           String
  outcome          String
  winnerAgentKey   String?
  winnerName       String?
  winningSide      String?
  finalBalance     Float?
  pnlUsd           Float?
  settledAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  round            Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
}

model BattleProofRecord {
  id                  String    @id @default(cuid())
  roundId             String    @unique
  proofVersion        Int
  proofHash           String
  proofHashEncoding   String
  payload             String
  onchainProofAddress String?
  onchainSignature    String?
  anchoredAt          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  round               Round     @relation(fields: [roundId], references: [id], onDelete: Cascade)
}

model FactPriceTick {
  id             String   @id @default(cuid())
  symbol         String
  price          Float
  sourceLabel    String
  observedAt     DateTime
  rawPayloadHash String?
  createdAt      DateTime @default(now())

  @@unique([symbol, sourceLabel, observedAt])
  @@index([symbol, observedAt])
}

model MarketTick {
  id             String   @id @default(cuid())
  sourceKey      String
  marketId       String
  conditionId    String?
  tokenId        String
  side           String
  price          Float
  sourceLabel    String
  observedAt     DateTime
  rawPayloadHash String?
  createdAt      DateTime @default(now())

  @@unique([sourceKey, tokenId, observedAt])
  @@index([sourceKey, marketId, observedAt])
  @@index([tokenId, observedAt])
  @@index([conditionId])
}

model RoundPriceSnapshot {
  id          String   @id @default(cuid())
  roundId      String
  price       Float
  sourceLabel String
  capturedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  round       Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  actions     Action[]

  @@index([roundId, capturedAt])
}
