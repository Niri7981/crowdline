generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "sqlite"
}

model EventPoolItem {
  id               String   @id @default(cuid())
  sourceKey        String
  externalEventId  String
  externalMarketId String?
  slug             String?
  title            String
  question         String
  category         String
  marketSymbol     String
  yesLabel         String
  noLabel          String
  startsAt         DateTime?
  endsAt           DateTime?
  durationSeconds  Int
  resolutionSource String
  sourceLabel      String
  externalUrl      String?
  currentPrice     Float?
  volumeUsd        Float?
  liquidityScore   Float?
  status           String
  playable         Boolean  @default(true)
  spectatorNote    String
  stageLabel       String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  orders           CrowdlineOrder[]
  fills            CrowdlineFill[]
  positions        CrowdlinePosition[]

  @@unique([sourceKey, externalEventId])
  @@index([status, playable])
  @@index([marketSymbol])
}

model MarketTick {
  id             String   @id @default(cuid())
  sourceKey      String
  marketId       String
  conditionId    String?
  tokenId        String
  side           String
  price          Float
  sourceLabel    String
  observedAt     DateTime
  rawPayloadHash String?
  createdAt      DateTime @default(now())

  @@unique([sourceKey, tokenId, observedAt])
  @@index([sourceKey, marketId, observedAt])
  @@index([tokenId, observedAt])
  @@index([conditionId])
}

model WalletAccount {
  id                  String              @id @default(cuid())
  walletKind          String
  walletAddress       String
  normalizedAddress   String
  networkLabel        String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  creditLedgerEntries CreditLedgerEntry[]
  orders              CrowdlineOrder[]
  fills               CrowdlineFill[]
  positions           CrowdlinePosition[]

  @@unique([walletKind, normalizedAddress])
  @@index([normalizedAddress])
}

model CreditLedgerEntry {
  id              String        @id @default(cuid())
  walletAccountId String
  entryType       String
  amount          Float
  balanceAfter    Float?
  referenceType   String?
  referenceId     String?
  dedupeKey       String?       @unique
  note            String?
  createdAt       DateTime      @default(now())
  walletAccount   WalletAccount @relation(fields: [walletAccountId], references: [id], onDelete: Cascade)

  @@index([walletAccountId, createdAt])
  @@index([referenceType, referenceId])
}

model CrowdlineOrder {
  id              String          @id @default(cuid())
  walletAccountId String
  marketId        String
  side            String
  amount          Float
  quotePrice      Float
  shares          Float
  status          String
  marketTitle     String
  createdAt       DateTime        @default(now())
  filledAt        DateTime?
  walletAccount   WalletAccount   @relation(fields: [walletAccountId], references: [id], onDelete: Cascade)
  market          EventPoolItem    @relation(fields: [marketId], references: [id], onDelete: Restrict)
  fill            CrowdlineFill?

  @@index([walletAccountId, createdAt])
  @@index([marketId, side])
  @@index([status, createdAt])
}

model CrowdlineFill {
  id              String         @id @default(cuid())
  orderId         String         @unique
  walletAccountId String
  marketId        String
  side            String
  amount          Float
  price           Float
  shares          Float
  createdAt       DateTime       @default(now())
  order           CrowdlineOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  walletAccount   WalletAccount  @relation(fields: [walletAccountId], references: [id], onDelete: Cascade)
  market          EventPoolItem   @relation(fields: [marketId], references: [id], onDelete: Restrict)

  @@index([walletAccountId, createdAt])
  @@index([marketId, side])
}

model CrowdlinePosition {
  id              String        @id @default(cuid())
  walletAccountId String
  marketId        String
  side            String
  shares          Float
  avgPrice        Float
  spent           Float
  realizedPnl     Float         @default(0)
  openedAt        DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  walletAccount   WalletAccount @relation(fields: [walletAccountId], references: [id], onDelete: Cascade)
  market          EventPoolItem  @relation(fields: [marketId], references: [id], onDelete: Restrict)

  @@unique([walletAccountId, marketId, side])
  @@index([marketId, side])
  @@index([walletAccountId, updatedAt])
}
